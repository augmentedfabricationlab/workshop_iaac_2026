                    <item name="UserText" type_name="gh_string" type_code="10">{"assignment":[{"nodeKey":"0","brickId":"stack1_brick26","usedDamageIdx":[],"note":"Bottommost node, assigned an undamaged brick (0)."},{"nodeKey":"1","brickId":"stack1_brick28","usedDamageIdx":[],"note":"Bottommost node, assigned an undamaged brick (0)."},{"nodeKey":"10","brickId":"stack1_brick8","usedDamageIdx":[],"note":"Mid-column, maintaining gradient with damage count 5."},{"nodeKey":"11","brickId":"stack1_brick24","usedDamageIdx":[],"note":"Mid-column, maintaining gradient with damage count 4."},{"nodeKey":"12","brickId":"stack1_brick19","usedDamageIdx":[],"note":"Upper-mid column, damage count 5."},{"nodeKey":"13","brickId":"stack1_brick27","usedDamageIdx":[],"note":"Upper-mid column, damage count 5."},{"nodeKey":"14","brickId":"stack1_brick29","usedDamageIdx":[],"note":"Upper column, high damage (7)."},{"nodeKey":"15","brickId":"stack1_brick12","usedDamageIdx":[],"note":"Upper column, continuing gradient with damage count 6."},{"nodeKey":"16","brickId":"stack1_brick1","usedDamageIdx":[],"note":"Upper column, high damage (7)."},{"nodeKey":"17","brickId":"stack1_brick9","usedDamageIdx":[],"note":"Upper column, high damage (7)."},{"nodeKey":"18","brickId":"stack1_brick11","usedDamageIdx":[],"note":"Top section, very high damage (8)."},{"nodeKey":"19","brickId":"stack1_brick23","usedDamageIdx":[],"note":"Top section, very high damage (8)."},{"nodeKey":"2","brickId":"stack1_brick13","usedDamageIdx":[],"note":"Bottom section, assigned brick with minimal damage (1)."},{"nodeKey":"20","brickId":"stack1_brick10","usedDamageIdx":[],"note":"Top section, very high damage (9)."},{"nodeKey":"21","brickId":"stack1_brick38","usedDamageIdx":[],"note":"Top section, very high damage (9)."},{"nodeKey":"22","brickId":"stack1_brick2","usedDamageIdx":[],"note":"Topmost node, assigned a brick with maximum damage (10)."},{"nodeKey":"23","brickId":"stack1_brick14","usedDamageIdx":[],"note":"Topmost node, assigned a brick with maximum damage (10)."},{"nodeKey":"3","brickId":"stack1_brick18","usedDamageIdx":[],"note":"Bottom section, assigned brick with minimal damage (1)."},{"nodeKey":"4","brickId":"stack1_brick17","usedDamageIdx":[],"note":"Lower section, low damage (2)."},{"nodeKey":"5","brickId":"stack1_brick3","usedDamageIdx":[],"note":"Lower section, low damage (2)."},{"nodeKey":"6","brickId":"stack1_brick15","usedDamageIdx":[],"note":"Lower section, damage count 3."},{"nodeKey":"7","brickId":"stack1_brick16","usedDamageIdx":[],"note":"Lower section, damage count 3."},{"nodeKey":"8","brickId":"stack1_brick32","usedDamageIdx":[],"note":"Lower-mid column, damage count 4."},{"nodeKey":"9","brickId":"stack1_brick33","usedDamageIdx":[],"note":"Lower-mid column, damage count 4."}],"notes":"A vertical gradient of damage was created by sorting nodes by height and assigning bricks with damage counts decreasing from top to bottom. The most damaged bricks (count 10) are at the top, and undamaged bricks (count 0) are at the bottom, with a smooth transition in between to create high polarity."}
