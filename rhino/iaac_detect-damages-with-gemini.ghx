                    <item name="ID" index="0" type_name="gh_guid" type_code="9">d1fc5373-cc3b-41cf-ac11-3b8411d44d52</item>
                    <item name="ID" index="1" type_name="gh_guid" type_code="9">f3e7785c-5380-41aa-8f25-877c5138b07f</item>
                    <item name="ID_Count" type_name="gh_int32" type_code="3">2</item>
